<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-black">카테고리 관리</h1>
</div>

<%# 게시판 카테고리 섹션 %>
<section class="mb-10">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-bold">게시판 카테고리</h2>
    <%= link_to "새 게시판 카테고리", new_admin_category_path(record_type: "post"),
      class: "bg-tv-gold text-tv-black rounded-pill px-4 py-2 text-sm font-bold" %>
  </div>
  <div class="bg-white rounded-card overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 text-xs text-tv-gray uppercase">
        <tr>
          <th class="px-4 py-3 text-left w-10"></th>
          <th class="px-4 py-3 text-left">이름 / 슬러그</th>
          <th class="px-4 py-3 text-left">설명</th>
          <th class="px-4 py-3 text-center">게시글 수</th>
          <th class="px-4 py-3 text-center">관리자 전용</th>
          <th class="px-4 py-3 text-center">Navbar 노출</th>
          <th class="px-4 py-3 text-center">순서</th>
          <th class="px-4 py-3 text-right">액션</th>
        </tr>
      </thead>
      <tbody class="divide-y" data-controller="sortable" data-sortable-url-value="<%= reorder_admin_categories_path %>">
        <% @post_categories.each do |category| %>
          <%= render "category_row", category: category %>
        <% end %>
      </tbody>
    </table>
    <% if @post_categories.empty? %>
      <p class="text-center text-tv-gray py-8 text-sm">게시판 카테고리가 없습니다.</p>
    <% end %>
  </div>
</section>

<%# 스킬팩 카테고리 섹션 %>
<section>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-bold">스킬팩 카테고리</h2>
    <%= link_to "새 스킬팩 카테고리", new_admin_category_path(record_type: "skill_pack"),
      class: "bg-tv-gold text-tv-black rounded-pill px-4 py-2 text-sm font-bold" %>
  </div>
  <div class="bg-white rounded-card overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 text-xs text-tv-gray uppercase">
        <tr>
          <th class="px-4 py-3 text-left w-10"></th>
          <th class="px-4 py-3 text-left">이름 / 슬러그</th>
          <th class="px-4 py-3 text-left">설명</th>
          <th class="px-4 py-3 text-center">스킬팩 수</th>
          <th class="px-4 py-3 text-center">관리자 전용</th>
          <th class="px-4 py-3 text-center">Navbar 노출</th>
          <th class="px-4 py-3 text-center">순서</th>
          <th class="px-4 py-3 text-right">액션</th>
        </tr>
      </thead>
      <tbody class="divide-y" data-controller="sortable" data-sortable-url-value="<%= reorder_admin_categories_path %>">
        <% @skill_pack_categories.each do |category| %>
          <%= render "category_row", category: category %>
        <% end %>
      </tbody>
    </table>
    <% if @skill_pack_categories.empty? %>
      <p class="text-center text-tv-gray py-8 text-sm">스킬팩 카테고리가 없습니다.</p>
    <% end %>
  </div>
</section>
