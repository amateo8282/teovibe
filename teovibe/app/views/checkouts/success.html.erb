<% content_for :title, "결제 완료 - #{@skill_pack.title}" %>

<div class="max-w-lg mx-auto px-5 py-16 text-center">
  <div class="bg-white rounded-2xl shadow-sm p-10">
    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <h1 class="text-2xl font-black text-gray-900 mb-4">결제 확인 중입니다...</h1>
    <p class="text-gray-600 mb-8">
      결제가 완료되었습니다. 결제 내역을 확인하고 있습니다.
      잠시 후 스킬팩에 접근 가능합니다.
    </p>

    <%= link_to skill_pack_path(@skill_pack),
      class: "inline-block bg-tv-orange text-white rounded-lg px-8 py-3 font-semibold hover:bg-orange-600 transition-colors" do %>
      스킬팩으로 이동
    <% end %>
  </div>

  <%# 개발 환경에서만 debug 정보 표시 %>
  <% if Rails.env.development? %>
    <div class="mt-8 p-4 bg-gray-100 rounded-lg text-left text-sm text-gray-600">
      <p class="font-bold mb-2">Debug (개발 환경)</p>
      <p>paymentKey: <%= params[:paymentKey] %></p>
      <p>orderId: <%= params[:orderId] %></p>
      <p>amount: <%= params[:amount] %></p>
    </div>
  <% end %>
</div>
