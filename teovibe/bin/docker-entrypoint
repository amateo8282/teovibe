#!/bin/bash -e

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails db:prepare DATABASE=queue
  ./bin/rails db:prepare DATABASE=cache
  ./bin/rails db:prepare DATABASE=cable
fi

exec "${@}"
